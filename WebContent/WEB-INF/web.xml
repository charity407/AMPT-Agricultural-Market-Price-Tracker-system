<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>AgriPrice KE</display-name>

    <!-- ── AUTH (Member 2) ── -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserManagementServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.UserManagementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserManagementServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <!-- ── PRODUCTS & MARKETS (Member 3) ── -->
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/admin/products</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MarketServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.MarketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MarketServlet</servlet-name>
        <url-pattern>/admin/markets</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.CategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/admin/categories</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegionServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.RegionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegionServlet</servlet-name>
        <url-pattern>/admin/regions</url-pattern>
    </servlet-mapping>

    <!-- ── PRICES & ALERTS (Member 4 — YOU) ── -->
    <servlet>
        <servlet-name>PriceEntryServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.PriceEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceEntryServlet</servlet-name>
        <url-pattern>/prices/entry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PriceListServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.PriceListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceListServlet</servlet-name>
        <url-pattern>/prices/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PriceEditServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.PriceEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceEditServlet</servlet-name>
        <url-pattern>/prices/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PriceCompareServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.PriceCompareServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceCompareServlet</servlet-name>
        <url-pattern>/prices/compare</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PriceTrendServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.PriceTrendServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceTrendServlet</servlet-name>
        <url-pattern>/prices/trends</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AlertServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.AlertServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AlertServlet</servlet-name>
        <url-pattern>/alerts</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AlertCheckServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.AlertCheckServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AlertCheckServlet</servlet-name>
        <url-pattern>/alerts/check</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.agriprice.servlets.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/reports</url-pattern>
    </servlet-mapping>

    <!-- ── SESSION ATTRIBUTE NAMES (for the whole team) ──
         Every member MUST use these exact names:
         session.setAttribute("userId",   user.getUserId());
         session.setAttribute("userRole", user.getRole());
         session.setAttribute("userName", user.getFullName());
    -->

    <!-- Default welcome page -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

</web-app>
